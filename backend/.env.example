# Project Settings → API. URL ends with .supabase.co (no trailing slash).
SUPABASE_URL=
# Must be the service_role secret (long JWT), NOT the anon public key.
SUPABASE_SERVICE_KEY=
GEMINI_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=reminders@yourdomain.com
FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=https://your-app.railway.app
SCHEDULER_TIMEZONE=Asia/Kolkata
# Cloudinary (medical document uploads). Create at https://cloudinary.com — folder is created on first upload.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local LLM for adherence insights (Ollama). Install Ollama and pull this model.
# If Ollama is unavailable, the backend falls back to Gemini.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_INSIGHT_MODEL=llama3.1:8b-instruct
OLLAMA_TIMEOUT_SECONDS=8
OLLAMA_TEMPERATURE=0.2
OLLAMA_NUM_PREDICT=180
